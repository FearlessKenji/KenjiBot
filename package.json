{
  "dependencies": {
    "cron": "^3.1.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "he": "^1.2.0",
    "luxon": "^3.7.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "tar": "^7.5.16"
  },
  "overrides": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4"
  },
  "name": "Hachi",
  "description": "This Discord bot will automatically send a message and tag the assigned role whenever a streamer went live.\r The notifications will update every 10 minutes(default) while the streamer is live.",
  "version": "3.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node .",
    "build:hachigen": "npm --prefix manager run dist && node -e \"require('node:fs').copyFileSync('manager/dist/HachiGen.exe', 'HachiGen.exe')\"",
    "db:audit": "node database/dbAudit.js",
    "db:migrate": "node database/dbAudit.js --migrate",
    "db:migrate:force": "node database/dbAudit.js --force",
    "lint": "eslint . --config config/eslint.config.js",
    "lint:fix": "eslint . --config config/eslint.config.js --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/FearlessKenji/Hachi.git"
  },
  "keywords": [
    "discord",
    "bot",
    "twitch",
    "reddit",
    "notification",
    "notify"
  ],
  "author": "FearlessKenji",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/FearlessKenji/Hachi/issues"
  },
  "homepage": "https://github.com/FearlessKenji/Hachi#readme",
  "engines": {
    "node": ">=18.18.0"
  },
  "type": "commonjs"
}
